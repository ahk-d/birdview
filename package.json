{
  "name": "birdview",
  "version": "1.0.1",
  "description": "A fast, private, local-first productivity dashboard for tasks, projects, jobs, notes and screenshots — right in your new tab.",
  "license": "MIT",
  "type": "module",
  "author": "ahk-d",
  "homepage": "https://github.com/ahk-d/birdview#readme",
  "repository": { "type": "git", "url": "https://github.com/ahk-d/birdview.git" },
  "bugs": { "url": "https://github.com/ahk-d/birdview/issues" },
  "keywords": [
    "browser-extension",
    "chrome-extension",
    "firefox-addon",
    "manifest-v3",
    "productivity",
    "dashboard",
    "kanban",
    "local-first",
    "offline",
    "privacy",
    "react",
    "typescript",
    "vite",
    "tailwindcss",
    "new-tab",
    "task-manager",
    "notion-alternative"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:firefox": "cross-env BIRDVIEW_TARGET=firefox tsc -b && cross-env BIRDVIEW_TARGET=firefox vite build --outDir dist-firefox",
    "preview": "vite preview",
    "zip": "node scripts/zip.mjs",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/modifiers": "^7.0.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@headlessui/react": "^2.1.8",
    "@tanstack/react-virtual": "^3.10.8",
    "clsx": "^2.1.1",
    "framer-motion": "^11.5.4",
    "fuse.js": "^7.0.0",
    "idb": "^8.0.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.441.0",
    "nanoid": "^5.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "webextension-polyfill": "^0.12.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.26",
    "@playwright/test": "^1.47.1",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/chrome": "^0.0.271",
    "@types/node": "^22.5.5",
    "@types/react": "^18.3.7",
    "@types/react-dom": "^18.3.0",
    "@types/webextension-polyfill": "^0.12.1",
    "@typescript-eslint/eslint-plugin": "^8.6.0",
    "@typescript-eslint/parser": "^8.6.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.12",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.12",
    "typescript": "^5.6.2",
    "vite": "^5.4.6",
    "vitest": "^2.1.1"
  }
}
